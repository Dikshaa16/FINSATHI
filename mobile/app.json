{
  "expo": {
    "name": "FinTech SMS Extractor",
    "slug": "fintech-sms-extractor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fintech.smsextractor"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.fintech.smsextractor",
      "permissions": [
        "INTERNET",
        "READ_SMS",
        "RECEIVE_SMS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://localhost:3001/api",
      "eas": {
        "projectId": "12fec1af-26df-4dfa-ba05-649e441bde18"
      }
    }
  }
}
